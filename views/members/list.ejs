<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-0">Member Management</h2>
        <p class="text-muted small">Manage your library's registered members and their details.</p>
    </div>
    <a href="/members/add" class="btn btn-primary shadow-sm">
        <i class="bi bi-person-plus me-1"></i> Add New Member
    </a>
</div>

<div class="card shadow-sm border-0">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light text-muted">
                <tr>
                    <th class="px-4">Name</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Address</th>
                    <th class="text-end px-4">Actions</th>
                </tr>
            </thead>
            <tbody>
                <% if (members.length > 0) { %>
                    <% members.forEach(member => { %>
                        <tr>
                            <td class="px-4 fw-bold">
                                <div class="d-flex align-items-center">
                                    <img src="https://ui-avatars.com/api/?name=<%= member.name %>&background=random" class="rounded-circle me-3" width="32" height="32">
                                    <%= member.name %>
                                </div>
                            </td>
                            <td><%= member.email %></td>
                            <td><%= member.phone || '-' %></td>
                            <td><span class="small text-muted"><%= member.address || '-' %></span></td>
                            <td class="text-end px-4">
                                <div class="btn-group">
                                    <a href="/members/edit/<%= member.id %>" class="btn btn-sm btn-outline-secondary" title="Edit"><i class="bi bi-pencil"></i></a>
                                    <button class="btn btn-sm btn-outline-danger" title="Delete" onclick="confirmDeleteMembers(<%= member.id %>, '<%= member.name %>')"><i class="bi bi-trash"></i></button>
                                </div>
                            </td>
                        </tr>
                    <% }); %>
                <% } else { %>
                    <tr>
                        <td colspan="5" class="text-center py-5 text-muted">
                            <i class="bi bi-people fs-2 mb-2 d-block"></i>
                            No members found.
                        </td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
    <div class="p-4 bg-light border-top rounded-bottom d-flex justify-content-between align-items-center">
        <span class="text-muted small">Showing <%= members.length %> members</span>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteMemberModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">Confirm Deletion</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body py-4">
                <p class="mb-0">Are you sure you want to delete member <span id="memberNameToDelete" class="fw-bold"></span>? This action cannot be undone.</p>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-light border px-4" data-bs-dismiss="modal">Cancel</button>
                <a id="confirmDeleteMemberBtn" href="#" class="btn btn-danger px-4">Delete Member</a>
            </div>
        </div>
    </div>
</div>

<script>
function confirmDeleteMembers(id, name) {
    document.getElementById('memberNameToDelete').textContent = name;
    document.getElementById('confirmDeleteMemberBtn').href = '/members/delete/' + id;
    new bootstrap.Modal(document.getElementById('deleteMemberModal')).show();
}
</script>

